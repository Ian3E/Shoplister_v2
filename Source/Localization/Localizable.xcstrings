          }
        }
      }
    },
    "This restores the default item library and sections, and clears your shopping list. Any items you added or edited will be removed." : {
      "comment" : "Alert message when changing library language",
      "localizations" : {
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "פעולה זו משחזרת את ספריית הפריטים והקבוצות כברירת מחדל ומנקה את רשימת הקניות. כל פריט שהוספתם או ערכתם יוסר."
          }
        }
      }
    },
    "This will delete all library items and sections and cannot be undone." : {
      "comment" : "Footer under clear library button in item library settings",
      "localizations" : {
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "פעולה זו תמחק את כל פריטי הספרייה והקבוצות ולא ניתן לבטלה."
          }
