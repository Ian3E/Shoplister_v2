    "Add a photo from your library or camera. Photos appear on items in your library and shopping list." : {
      "comment" : "App feature description: item photos",
      "extractionState" : "stale",
      "localizations" : {
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הוסיפו תמונה מהגלריה או מהמצלמה. התמונות מופיעות על פריטים בספרייה וברשימת הקניות."
          }
        }
      }
    },
    "Add a photo to an item from your library or camera. Long-press an item in your shopping list to preview the photo." : {
      "comment" : "App feature description: item photos",
      "localizations" : {
        "he" : {
          "stringUnit" : {
            "state" : "translated",
